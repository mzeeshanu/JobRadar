@inherits LayoutComponentBase

<MudLayout>
    <MudAppBar Elevation="4" Dense="false" Style="background: linear-gradient(90deg,#0D0D1A 0%,#1a1a3e 100%);">
        <MudIcon Icon="@Icons.Material.Filled.MyLocation" Class="mr-2" Style="color:#6C63FF" />
        <MudText Typo="Typo.h6" Style="font-weight:800;letter-spacing:2px;color:#E0E0FF">JOB RADAR</MudText>
        <MudSpacer />
        <MudText Typo="Typo.caption" Style="color:#9E9EC8">Discover local opportunities</MudText>
    </MudAppBar>

    <MudMainContent Class="pt-16" Style="background:#0F0F1A;min-height:100vh">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>
