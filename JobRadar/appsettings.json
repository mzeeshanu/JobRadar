{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Storage": {
    "Provider": "sqlite",
    "JsonFile": {
      "Path": "jobradar-cache.json"
    }
  },

  "Cache": {
    "CompanyTtlHours": 24,
    "JobTtlHours": 8,
    "FailedCrawlRetryHours": 1
  },

  "Search": {
    "RadiusMeters": 20000,
    "Keywords": [
      "software company",
      "technology company",
      "IT company",
      "software development",
      "tech company office",
      "enterprise software",
      "technology campus",
      "corporate technology",
      "software corporation",
      "technology park",
      "financial technology",
      "healthcare technology",
      "engineering firm",
      "consulting firm",
      "startup office",
      "corporation headquarters",
      "tech hub"
    ],
    "OsmFilters": [
      "office=it",
      "office=company",
      "office=financial",
      "amenity=university",
      "amenity=hospital",
      "office=software",
      "office=technology"
    ]
  },

  "Providers": {
    "Companies": {
      "OpenStreetMapOverpass": { "Enabled": true },
      "GooglePlaces": {
        "Enabled": true,
        "ApiKey": ""
      }
    },
    "Jobs": {
      "Remotive":          { "Enabled": true },
      "TheMuse":           { "Enabled": true, "ApiKey": "" },
      "Adzuna": {
        "Enabled":  false,
        "AppId":    "",
        "ApiKey":   "",
        "Country":  "us"
      },
      "CareerPageCrawler": { "Enabled": true }
    }
  }
}
